@using SistemaAereo.Models.Entities
@model Airport

@{
    ViewData["Title"] = "Novo Aeroporto";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="fas fa-building"></i> Novo Aeroporto</h1>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label">Nome do Aeroporto</label>
                <input asp-for="Name" class="form-control" placeholder="Ex: Aeroporto Internacional de São Paulo" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="IATACode" class="control-label">Código IATA</label>
                <input asp-for="IATACode" class="form-control" placeholder="Ex: GRU, GIG" maxlength="3" style="text-transform:uppercase" />
                <span asp-validation-for="IATACode" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="City" class="control-label">Cidade</label>
                <input asp-for="City" class="form-control" placeholder="Ex: São Paulo" />
                <span asp-validation-for="City" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Country" class="control-label">País</label>
                <input asp-for="Country" class="form-control" placeholder="Ex: Brasil" />
                <span asp-validation-for="Country" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save"></i> Cadastrar Aeroporto
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}