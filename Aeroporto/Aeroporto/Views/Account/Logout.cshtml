@{
    ViewData["Title"] = "Logout";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Logout - Sistema de Gestão Aérea</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <meta http-equiv="refresh" content="2;url=@Url.Action("Login", "Account")" />
</head>
<body>
    <div class="container text-center" style="margin-top: 100px;">
        <div class="card shadow-lg" style="max-width: 500px; margin: 0 auto;">
            <div class="card-body p-5">
                <i class="fas fa-sign-out-alt fa-4x text-primary mb-3"></i>
                <h3>Logout realizado com sucesso!</h3>
                <p>Você será redirecionado para a página de login em alguns segundos...</p>
                <a asp-action="Login" asp-controller="Account" class="btn btn-primary">
                    <i class="fas fa-sign-in-alt me-2"></i>Ir para Login
                </a>
            </div>
        </div>
    </div>
</body>
</html>