@using SistemaAereo.Models.Entities
@model Aircraft

@{
    ViewData["Title"] = "Excluir Aeronave";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="fas fa-trash-alt"></i> Excluir Aeronave</h1>
</div>

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle"></i> @TempData["Erro"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="alert alert-warning">
    <i class="fas fa-exclamation-triangle"></i>
    <strong>Atenção!</strong> Você está prestes a excluir esta aeronave. Esta ação não pode ser desfeita.
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Dados da Aeronave</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.AircraftType)</dt>
                    <dd class="col-sm-8">@Model.AircraftType</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.NumberOfSeats)</dt>
                    <dd class="col-sm-8">@Model.NumberOfSeats</dd>

                    <dt class="col-sm-4">Total de Voos</dt>
                    <dd class="col-sm-8">@(Model.Flights?.Count ?? 0)</dd>
                </dl>

                <form asp-action="Delete" method="post">
                    <input type="hidden" name="id" value="@Model.AircraftId" />
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash"></i> Confirmar Exclusão
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                </form>
            </div>
        </div>
    </div>
</div>