@using SistemaAereo.Models.Entities
@model IEnumerable<Aircraft>

@{
    ViewData["Title"] = "Aeronaves";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="fas fa-plane"></i> Aeronaves</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus"></i> Nova Aeronave
        </a>
    </div>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle"></i> @TempData["Erro"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Tipo</th>
                <th>Poltronas</th>
                <th>Voos</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var aircraft in Model)
            {
                <tr>
                    <td>@aircraft.AircraftType</td>
                    <td>@aircraft.NumberOfSeats</td>
                    <td>@(aircraft.Flights?.Count ?? 0)</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@aircraft.AircraftId" class="btn btn-warning btn-sm">
                            <i class="fas fa-edit"></i>
                        </a>
                        <form asp-action="Delete" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@aircraft.AircraftId" />
                            <button type="submit" class="btn btn-danger btn-sm"
                                    onclick="return confirm('Tem certeza que deseja excluir esta aeronave?')">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">
        <i class="fas fa-info-circle"></i> Nenhuma aeronave cadastrada.
        <a asp-action="Create" class="alert-link">Clique aqui para cadastrar a primeira aeronave.</a>
    </div>
}