@using SistemaAereo.Models.Entities
@using SistemaAereo.Models.Enums
@model IEnumerable<Seat>

@{
    ViewData["Title"] = $"Poltronas do Voo {ViewBag.Flight?.FlightNumber}";
    var flight = ViewBag.Flight as Flight;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        <div>
            <h1 class="h2"><i class="fas fa-chair"></i> Poltronas do Voo @flight?.FlightNumber</h1>
            <p class="text-muted">
                <i class="fas fa-plane-departure"></i> @flight?.DepartureAirport?.Name (@flight?.DepartureAirport?.IATACode) →
                <i class="fas fa-plane-arrival"></i> @flight?.ArrivalAirport?.Name (@flight?.ArrivalAirport?.IATACode)
                <br />
                <i class="fas fa-calendar"></i> Saída: @flight?.DepartureTime.ToString("dd/MM/yyyy HH:mm")
            </p>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-secondary me-2">
                <i class="fas fa-arrow-left"></i> Voltar
            </a>
            @if (flight?.DepartureTime > DateTime.Now)
            {
                <form asp-action="RecreateSeats" asp-route-id="@flight?.FlightId" method="post" class="d-inline"
                      onsubmit="return confirm('Tem certeza que deseja recriar todas as poltronas? Isso irá remover as poltronas existentes.');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-warning">
                        <i class="fas fa-sync-alt"></i> Recriar Poltronas
                    </button>
                </form>
            }
        </div>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["Erro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Estatísticas -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary">
                <div class="card-body text-center">
                    <h5 class="card-title">Total de Poltronas</h5>
                    <h2 class="mb-0">@Model.Count()</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success">
                <div class="card-body text-center">
                    <h5 class="card-title">Disponíveis</h5>
                    <h2 class="mb-0">@Model.Count(s => s.IsAvailable)</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-danger">
                <div class="card-body text-center">
                    <h5 class="card-title">Ocupadas</h5>
                    <h2 class="mb-0">@Model.Count(s => !s.IsAvailable)</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info">
                <div class="card-body text-center">
                    <h5 class="card-title">Faturamento Potencial</h5>
                    <h2 class="mb-0">@Model.Sum(s => s.Price).ToString("C")</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Mapa de Poltronas -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Mapa de Ocupação</h6>
        </div>
        <div class="card-body">
            <div class="text-center mb-3">
                <span class="badge bg-success p-2 me-3">■ Disponível</span>
                <span class="badge bg-danger p-2 me-3">■ Ocupada</span>
                <span class="badge bg-warning p-2">■ Primeira Classe</span>
                <span class="badge bg-info p-2 ms-3">■ Executiva</span>
                <span class="badge bg-secondary p-2">■ Econômica</span>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered text-center">
                    <thead class="table-light">
                        <tr>
                            <th>Fileira</th>
                            <th>A</th>
                            <th>B</th>
                            <th>C</th>
                            <th>D</th>
                            <th>E</th>
                            <th>F</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var rows = Model.GroupBy(s => int.Parse(s.SeatNumber.Substring(0, s.SeatNumber.Length - 1)))
                                .OrderBy(g => g.Key);
                        }
                        @foreach (var row in rows)
                        {
                            <tr>
                                <td><strong>@row.Key</strong></td>
                                @{
                                    var seatsByLetter = row.ToDictionary(s => s.SeatNumber.Last().ToString(), s => s);
                                    var letters = new[] { "A", "B", "C", "D", "E", "F" };
                                }
                                @foreach (var letter in letters)
                                {
                                    if (seatsByLetter.ContainsKey(letter))
                                    {
                                        var seat = seatsByLetter[letter];
                                        var seatClassColor = seat.Class switch
                                        {
                                            SeatClass.FirstClass => "warning",
                                            SeatClass.Executive => "info",
                                            _ => "secondary"
                                        };
                                        var statusColor = seat.IsAvailable ? "success" : "danger";

                                        <td class="bg-@statusColor bg-opacity-25">
                                            <div class="p-2">
                                                <strong>@seat.SeatNumber</strong><br />
                                                <small class="text-muted">@seat.Class</small><br />
                                                <small>@seat.Location</small><br />
                                                <strong class="text-@seatClassColor">@seat.Price.ToString("C")</strong>
                                                @if (!seat.IsAvailable)
                                                {
                                                    <br />
                                                    <span class="badge bg-danger mt-1">OCUPADA</span>
                                                }
                                            </div>
                                        </td>
                                    }
                                    else
                                    {
                                        <td class="bg-light">
                                            <div class="p-2 text-muted">
                                                ---
                                            </div>
                                        </td>
                                    }
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Lista Detalhada -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Lista Detalhada de Poltronas</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-striped" id="dataTable" width="100%" cellspacing="0">
                    <thead class="table-dark">
                        <tr>
                            <th>Número</th>
                            <th>Tipo</th>
                            <th>Localização</th>
                            <th>Preço</th>
                            <th>Status</th>
                            <th>Status Venda</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var seat in Model.OrderBy(s => s.SeatNumber))
                        {
                            <tr>
                                <td><strong>@seat.SeatNumber</strong></td>
                                <td>
                                    @if (seat.Class == SeatClass.FirstClass)
                                    {
                                        <span class="badge bg-warning">Primeira</span>
                                    }
                                    else if (seat.Class == SeatClass.Executive)
                                    {
                                        <span class="badge bg-info">Executiva</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Econômica</span>
                                    }
                                </td>
                                <td>@seat.Location</td>
                                <td>@seat.Price.ToString("C")</td>
                                <td>
                                    @if (seat.IsAvailable)
                                    {
                                        <span class="badge bg-success">Disponível</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Ocupada</span>
                                    }
                                </td>
                                <td>
                                    @if (!seat.IsAvailable && flight?.DepartureTime > DateTime.Now)
                                    {
                                        <span class="text-danger">Vendida</span>
                                    }
                                    else if (seat.IsAvailable && flight?.DepartureTime > DateTime.Now)
                                    {
                                        <span class="text-success">À Venda</span>
                                    }
                                    else if (flight?.DepartureTime <= DateTime.Now)
                                    {
                                        <span class="text-muted">Voo Realizado</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#dataTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/pt-BR.json'
                },
                order: [[0, 'asc']],
                responsive: true
            });
        });
    </script>
}

<style>
    .bg-opacity-25 {
        --bs-bg-opacity: 0.25;
    }

    .table-bordered td, .table-bordered th {
        vertical-align: middle;
    }
</style>