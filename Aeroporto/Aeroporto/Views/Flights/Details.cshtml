@using SistemaAereo.Models.Entities
@model Flight

@{
    ViewData["Title"] = "Detalhes do Voo";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="fas fa-info-circle"></i> Detalhes do Voo</h1>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Voo @Model.FlightNumber</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6>Informações do Voo</h6>
                        <p><strong>Número:</strong> @Model.FlightNumber</p>
                        <p><strong>Aeronave:</strong> @Model.Aircraft?.AircraftType</p>
                        <p><strong>Saída:</strong> @Model.DepartureTime.ToString("dd/MM/yyyy HH:mm")</p>
                        <p><strong>Chegada Prevista:</strong> @Model.EstimatedArrivalTime.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                    <div class="col-md-6">
                        <h6>Rota</h6>
                        <p><strong>Origem:</strong> @Model.DepartureAirport?.Name (@Model.DepartureAirport?.IATACode)</p>
                        <p><strong>Destino:</strong> @Model.ArrivalAirport?.Name (@Model.ArrivalAirport?.IATACode)</p>
                        <p>
                            <strong>Status:</strong>
                            @if (Model.DepartureTime > DateTime.Now)
                            {
                                <span class="badge bg-success">Agendado</span>
                            }
                            else if (Model.EstimatedArrivalTime > DateTime.Now)
                            {
                                <span class="badge bg-primary">Em Andamento</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Concluído</span>
                            }
                        </p>
                    </div>
                </div>

                @if (Model.Stopovers?.Any() == true)
                {
                    <div class="mt-4">
                        <h6>Escalas</h6>
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Ordem</th>
                                        <th>Aeroporto</th>
                                        <th>Saída</th>
                                        <th>Chegada</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var stopover in Model.Stopovers.OrderBy(s => s.Order))
                                    {
                                        <tr>
                                            <td>@stopover.Order</td>
                                            <td>@stopover.Airport?.Name (@stopover.Airport?.IATACode)</td>
                                            <td>@stopover.DepartureTime.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>@(stopover.ArrivalTime?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                @if (Model.Seats?.Any() == true)
                {
                    <div class="mt-4">
                        <h6>Poltronas</h6>
                        <p>
                            <strong>Total:</strong> @Model.Seats.Count |
                            <strong>Disponíveis:</strong> @Model.Seats.Count(s => s.IsAvailable) |
                            <strong>Ocupadas:</strong> @Model.Seats.Count(s => !s.IsAvailable)
                        </p>
                    </div>
                }
            </div>
            <div class="card-footer">
                <a asp-action="Edit" asp-route-id="@Model.FlightId" class="btn btn-warning">
                    <i class="fas fa-edit"></i> Editar
                </a>
                <a asp-action="Index" class="btn btn-secondary">Voltar</a>
            </div>
        </div>
    </div>
</div>