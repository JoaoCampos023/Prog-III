@using SistemaAereo.Models.Entities
@model Voo

@{
    ViewData["Title"] = "Agendar Novo Voo";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-2 text-dark">
                <i class="fas fa-plane-departure text-primary me-2"></i>Agendar Novo Voo
            </h1>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Voltar
            </a>
        </div>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle me-2"></i>@TempData["Sucesso"]
        </div>
    }

    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Erro"]
        </div>
    }

    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Informações do Voo</h5>
        </div>
        <div class="card-body">
            <form method="post">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-warning">
                        <strong>Erros de validação:</strong>
                        <ul class="mb-0">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        </ul>
                    </div>
                }

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="NumeroVoo" class="form-label">Número do Voo *</label>
                        <input type="text" class="form-control" id="NumeroVoo" name="NumeroVoo"
                               value="@Model?.NumeroVoo" required maxlength="10"
                               placeholder="Ex: AA1234">
                        <div class="form-text">Código único de identificação do voo</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="AeronaveId" class="form-label">Aeronave *</label>
                        <select class="form-select" id="AeronaveId" name="AeronaveId" required>
                            <option value="">Selecione uma aeronave</option>
                            @if (ViewBag.Aeronaves != null)
                            {
                                foreach (var item in ViewBag.Aeronaves as List<SelectListItem>)
                                {
                                    if (Model?.AeronaveId.ToString() == item.Value)
                                    {
                                        <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            }
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="AeroportoOrigemId" class="form-label">Aeroporto de Origem *</label>
                        <select class="form-select" id="AeroportoOrigemId" name="AeroportoOrigemId" required>
                            <option value="">Selecione o aeroporto de origem</option>
                            @if (ViewBag.Aeroportos != null)
                            {
                                foreach (var item in ViewBag.Aeroportos as List<SelectListItem>)
                                {
                                    if (Model?.AeroportoOrigemId.ToString() == item.Value)
                                    {
                                        <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="AeroportoDestinoId" class="form-label">Aeroporto de Destino *</label>
                        <select class="form-select" id="AeroportoDestinoId" name="AeroportoDestinoId" required>
                            <option value="">Selecione o aeroporto de destino</option>
                            @if (ViewBag.Aeroportos != null)
                            {
                                foreach (var item in ViewBag.Aeroportos as List<SelectListItem>)
                                {
                                    if (Model?.AeroportoDestinoId.ToString() == item.Value)
                                    {
                                        <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            }
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="HorarioSaida" class="form-label">Horário de Saída *</label>
                        <input type="datetime-local" class="form-control" id="HorarioSaida" name="HorarioSaida"
                               value="@(Model?.HorarioSaida.ToString("yyyy-MM-ddTHH:mm") ?? "")" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="HorarioChegadaPrevisto" class="form-label">Horário Previsto de Chegada *</label>
                        <input type="datetime-local" class="form-control" id="HorarioChegadaPrevisto" name="HorarioChegadaPrevisto"
                               value="@(Model?.HorarioChegadaPrevisto.ToString("yyyy-MM-ddTHH:mm") ?? "")" required>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-2"></i>Agendar Voo
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-times me-2"></i>Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>