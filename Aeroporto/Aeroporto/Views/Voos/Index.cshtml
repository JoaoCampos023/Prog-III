@model IEnumerable<SistemaAereo.Models.Voo>

@{
    ViewData["Title"] = "Gestão de Voos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-2 text-dark">
            <i class="fas fa-plane-departure text-primary me-2"></i>Gestão de Voos
        </h1>
        <p class="text-muted mb-0">Controle completo da frota de voos</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-primary btn-modern">
            <i class="fas fa-filter me-2"></i>Filtrar
        </button>
        <a asp-action="Create" class="btn btn-primary-modern">
            <i class="fas fa-plus me-2"></i>Novo Voo
        </a>
    </div>
</div>

<!-- Alertas -->
@if (TempData["Sucesso"] != null)
{
    <div class="alert-modern alert-success">
        <div class="d-flex align-items-center">
            <i class="fas fa-check-circle me-3 fa-lg"></i>
            <div class="flex-grow-1">
                <h6 class="mb-1">Sucesso!</h6>
                <p class="mb-0">@TempData["Sucesso"]</p>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
}

@if (TempData["Erro"] != null)
{
    <div class="alert-modern alert-danger">
        <div class="d-flex align-items-center">
            <i class="fas fa-exclamation-circle me-3 fa-lg"></i>
            <div class="flex-grow-1">
                <h6 class="mb-1">Erro!</h6>
                <p class="mb-0">@TempData["Erro"]</p>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
}

<!-- Filtros Rápidos -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card-modern">
            <div class="card-body-modern">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Status</label>
                        <select class="form-select form-control-modern">
                            <option selected>Todos os Status</option>
                            <option>Agendados</option>
                            <option>Em Andamento</option>
                            <option>Concluídos</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Data Inicial</label>
                        <input type="date" class="form-control form-control-modern">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Data Final</label>
                        <input type="date" class="form-control form-control-modern">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Aeronave</label>
                        <select class="form-select form-control-modern">
                            <option selected>Todas as Aeronaves</option>
                            <option>Boeing 737</option>
                            <option>Airbus A320</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Card Principal -->
<div class="card-modern">
    <div class="card-header-modern d-flex justify-content-between align-items-center">
        <h5 class="mb-0 text-dark">Lista de Voos</h5>
        <div class="d-flex align-items-center gap-2">
            <span class="text-muted small">@Model.Count() voos encontrados</span>
            <div class="input-group input-group-sm" style="width: 200px;">
                <input type="text" class="form-control form-control-modern" placeholder="Buscar voo...">
                <button class="btn btn-outline-secondary" type="button">
                    <i class="fas fa-search"></i>
                </button>
            </div>
        </div>
    </div>
    <div class="card-body-modern p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-modern mb-0">
                    <thead>
                        <tr>
                            <th width="120">Voo</th>
                            <th>Rota</th>
                            <th>Horários</th>
                            <th>Aeronave</th>
                            <th>Status</th>
                            <th width="140">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var voo in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary bg-opacity-10 p-2 rounded me-3">
                                            <i class="fas fa-plane text-primary"></i>
                                        </div>
                                        <div>
                                            <strong class="d-block">@voo.NumeroVoo</strong>
                                            <small class="text-muted">ID: @voo.VooId</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div>
                                        <div class="fw-semibold">
                                            @voo.AeroportoOrigem?.CodigoIATA
                                            <i class="fas fa-arrow-right mx-2 text-muted"></i>
                                            @voo.AeroportoDestino?.CodigoIATA
                                        </div>
                                        <div class="text-muted small">
                                            @voo.AeroportoOrigem?.Cidade → @voo.AeroportoDestino?.Cidade
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div>
                                        <div class="fw-semibold">
                                            @voo.HorarioSaida.ToString("dd/MM HH:mm")
                                        </div>
                                        <div class="text-muted small">
                                            Chegada: @voo.HorarioChegadaPrevisto.ToString("dd/MM HH:mm")
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-warning bg-opacity-10 p-2 rounded me-2">
                                            <i class="fas fa-plane text-warning"></i>
                                        </div>
                                        <span class="fw-semibold">@voo.Aeronave?.TipoAeronave</span>
                                    </div>
                                </td>
                                <td>
                                    @if (voo.HorarioSaida > DateTime.Now)
                                    {
                                        <span class="badge-modern bg-success bg-opacity-10 text-success">
                                            <i class="fas fa-clock me-1"></i>Agendado
                                        </span>
                                    }
                                    else if (voo.HorarioChegadaPrevisto > DateTime.Now)
                                    {
                                        <span class="badge-modern bg-primary bg-opacity-10 text-primary">
                                            <i class="fas fa-play me-1"></i>Em Andamento
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge-modern bg-secondary bg-opacity-10 text-secondary">
                                            <i class="fas fa-check me-1"></i>Concluído
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Details" asp-route-id="@voo.VooId"
                                           class="btn btn-outline-info btn-sm"
                                           data-bs-toggle="tooltip" title="Detalhes">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@voo.VooId"
                                           class="btn btn-outline-warning btn-sm"
                                           data-bs-toggle="tooltip" title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form asp-action="Delete" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@voo.VooId" />
                                            <button type="submit"
                                                    class="btn btn-outline-danger btn-sm"
                                                    data-bs-toggle="tooltip"
                                                    title="Excluir"
                                                    onclick="return confirm('Tem certeza que deseja excluir este voo?')">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <div class="bg-light rounded-circle d-inline-flex p-4 mb-3">
                    <i class="fas fa-plane-slash fa-2x text-muted"></i>
                </div>
                <h5 class="text-muted">Nenhum voo cadastrado</h5>
                <p class="text-muted mb-4">Comece agendando o primeiro voo do sistema.</p>
                <a asp-action="Create" class="btn btn-primary-modern">
                    <i class="fas fa-plus me-2"></i>Agendar Primeiro Voo
                </a>
            </div>
        }
    </div>
</div>

<!-- Cards de Estatísticas -->
<div class="row mt-4">
    <div class="col-md-3">
        <div class="card-modern text-center">
            <div class="card-body-modern">
                <div class="text-primary mb-2">
                    <i class="fas fa-plane-departure fa-2x"></i>
                </div>
                <h4 class="text-dark">@Model.Count(v => v.HorarioSaida > DateTime.Now)</h4>
                <p class="text-muted mb-0">Voos Agendados</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card-modern text-center">
            <div class="card-body-modern">
                <div class="text-warning mb-2">
                    <i class="fas fa-plane fa-2x"></i>
                </div>
                <h4 class="text-dark">@Model.Count(v => v.HorarioSaida <= DateTime.Now && v.HorarioChegadaPrevisto > DateTime.Now)</h4>
                <p class="text-muted mb-0">Em Andamento</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card-modern text-center">
            <div class="card-body-modern">
                <div class="text-success mb-2">
                    <i class="fas fa-check-circle fa-2x"></i>
                </div>
                <h4 class="text-dark">@Model.Count(v => v.HorarioChegadaPrevisto <= DateTime.Now)</h4>
                <p class="text-muted mb-0">Concluídos</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card-modern text-center">
            <div class="card-body-modern">
                <div class="text-info mb-2">
                    <i class="fas fa-chart-line fa-2x"></i>
                </div>
                <h4 class="text-dark">@Model.Count()</h4>
                <p class="text-muted mb-0">Total de Voos</p>
            </div>
        </div>
    </div>
</div>