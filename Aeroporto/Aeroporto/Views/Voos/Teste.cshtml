@{
    ViewData["Title"] = "Teste do Sistema";
}

<div class="container mt-4">
    <h2>Diagnóstico do Sistema</h2>

    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h5 class="card-title">Aeroportos</h5>
                    <h2>@ViewBag.AeroportosCount</h2>
                    <p class="card-text">Cadastrados no sistema</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h5 class="card-title">Aeronaves</h5>
                    <h2>@ViewBag.AeronavesCount</h2>
                    <p class="card-text">Cadastradas no sistema</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-info">
                <div class="card-body">
                    <h5 class="card-title">Voos</h5>
                    <h2>@ViewBag.VoosCount</h2>
                    <p class="card-text">Cadastrados no sistema</p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <h4>Próximos Passos:</h4>
        <ol>
            <li>Verifique se há aeroportos cadastrados (mínimo 2)</li>
            <li>Verifique se há aeronaves cadastradas (mínimo 1)</li>
            <li>Teste criar um voo e observe o Console/Output</li>
            <li>Verifique os erros específicos que aparecem</li>
        </ol>
    </div>

    <div class="mt-4">
        <a asp-action="Create" class="btn btn-primary">Testar Criação de Voo</a>
        <a asp-action="Index" class="btn btn-secondary">Ver Lista de Voos</a>
    </div>
</div>