@using SistemaAereo.Models.Entities
@using SistemaAereo.Models.Enums
@model SistemaAereo.Models.ViewModels.PaginacaoViewModel<Passagem>

@{
    ViewData["Title"] = $"Passagens de {ViewBag.ClienteNome}";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2"><i class="fas fa-ticket-alt"></i> Passagens de @ViewBag.ClienteNome</h1>
        <div class="btn-toolbar mb-2 mb-md-0">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Voltar
            </a>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Lista de Passagens</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-striped" width="100%" cellspacing="0">
                    <thead class="table-dark">
                        <tr>
                            <th>Nº Bilhete</th>
                            <th>Voo</th>
                            <th>Poltrona</th>
                            <th>Data Emissão</th>
                            <th>Preço</th>
                            <th>Status</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var passagem in Model.Itens)
                        {
                            <tr>
                                <td><strong>@passagem.NumeroBilhete</strong></td>
                                <td>@passagem.Voo?.NumeroVoo</td>
                                <td>@passagem.Poltrona?.NumeroPoltrona</td>
                                <td>@passagem.DataEmissao.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@passagem.Preco.ToString("C")</td>
                                <td>
                                    @if (passagem.Status == PassagemStatus.Confirmada)
                                    {
                                        <span class="badge bg-primary">@passagem.Status</span>
                                    }
                                    else if (passagem.Status == PassagemStatus.CheckIn)
                                    {
                                        <span class="badge bg-warning">@passagem.Status</span>
                                    }
                                    else if (passagem.Status == PassagemStatus.Embarcada)
                                    {
                                        <span class="badge bg-success">@passagem.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@passagem.Status</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@passagem.PassagemId" class="btn btn-info btn-sm" title="Detalhes">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Paginação -->
            @if (Model.TotalPaginas > 1)
            {
                <nav aria-label="Navegação de páginas">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.TemPaginaAnterior ? "" : "disabled")">
                            <a class="page-link" asp-route-pagina="@(Model.PaginaAtual - 1)"
                               asp-route-itensPorPagina="@ViewBag.ItensPorPaginaAtual"
                               asp-route-id="@ViewBag.ClienteId">
                                <i class="fas fa-chevron-left"></i> Anterior
                            </a>
                        </li>

                        @for (int i = 1; i <= Model.TotalPaginas; i++)
                        {
                            if (i == Model.PaginaAtual)
                            {
                                <li class="page-item active">
                                    <span class="page-link">@i</span>
                                </li>
                            }
                            else if (Math.Abs(i - Model.PaginaAtual) <= 2 || i == 1 || i == Model.TotalPaginas)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-route-pagina="@i"
                                       asp-route-itensPorPagina="@ViewBag.ItensPorPaginaAtual"
                                       asp-route-id="@ViewBag.ClienteId">@i</a>
                                </li>
                            }
                            else if (Math.Abs(i - Model.PaginaAtual) == 3)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                        }

                        <li class="page-item @(Model.TemProximaPagina ? "" : "disabled")">
                            <a class="page-link" asp-route-pagina="@(Model.PaginaAtual + 1)"
                               asp-route-itensPorPagina="@ViewBag.ItensPorPaginaAtual"
                               asp-route-id="@ViewBag.ClienteId">
                                Próximo <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>