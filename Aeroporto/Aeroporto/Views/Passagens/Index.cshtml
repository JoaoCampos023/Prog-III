@model IEnumerable<SistemaAereo.Models.Passagem>

@{
    ViewData["Title"] = "Passagens";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2"><i class="fas fa-ticket-alt"></i> @ViewData["Title"]</h1>
        <div class="btn-toolbar mb-2 mb-md-0">
            <a asp-action="Create" class="btn btn-success">
                <i class="fas fa-plus"></i> Nova Passagem
            </a>
        </div>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["Erro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Lista de Passagens</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-striped" id="dataTable" width="100%" cellspacing="0">
                    <thead class="table-dark">
                        <tr>
                            <th>Nº Bilhete</th>
                            <th>Cliente</th>
                            <th>Voo</th>
                            <th>Poltrona</th>
                            <th>Data Emissão</th>
                            <th>Preço</th>
                            <th>Status</th>
                            <th width="150px">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var passagem in Model)
                        {
                            <tr>
                                <td><strong>@passagem.NumeroBilhete</strong></td>
                                <td>@passagem.Cliente?.Nome</td>
                                <td>@passagem.Voo?.NumeroVoo</td>
                                <td>@passagem.Poltrona?.NumeroPoltrona</td>
                                <td>@passagem.DataEmissao.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@passagem.Preco.ToString("C")</td>
                                <td>
                                    @if (passagem.Status == "Confirmada")
                                    {
                                        <span class="badge bg-primary">@passagem.Status</span>
                                    }
                                    else if (passagem.Status == "Check-in")
                                    {
                                        <span class="badge bg-warning">@passagem.Status</span>
                                    }
                                    else if (passagem.Status == "Embarcada")
                                    {
                                        <span class="badge bg-success">@passagem.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@passagem.Status</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@passagem.PassagemId" class="btn btn-info btn-sm" title="Detalhes">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        @if (passagem.Status == "Confirmada")
                                        {
                                            <a asp-action="Checkin" asp-route-id="@passagem.PassagemId" class="btn btn-warning btn-sm" title="Check-in">
                                                <i class="fas fa-check-in"></i>
                                            </a>
                                        }
                                        @if (passagem.Status == "Check-in")
                                        {
                                            <a asp-action="Embarque" asp-route-id="@passagem.PassagemId" class="btn btn-success btn-sm" title="Embarque">
                                                <i class="fas fa-plane"></i>
                                            </a>
                                        }
                                        @if (passagem.Status != "Cancelada")
                                        {
                                            <a asp-action="Cancelar" asp-route-id="@passagem.PassagemId" class="btn btn-danger btn-sm"
                                               onclick="return confirm('Tem certeza que deseja cancelar esta passagem?')"
                                               title="Cancelar">
                                                <i class="fas fa-times"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-ticket-alt fa-2x mb-3"></i>
            <h5>Nenhuma passagem emitida</h5>
            <p>Comece emitindo a primeira passagem do sistema.</p>
            <a asp-action="Create" class="btn btn-primary">Emitir Primeira Passagem</a>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#dataTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/pt-BR.json'
                },
                order: [[4, 'desc']],
                responsive: true
            });
        });
    </script>
}