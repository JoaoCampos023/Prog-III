@using SistemaAereo.Models.Entities
@using SistemaAereo.Models.Enums
@model SistemaAereo.Models.ViewModels.PaginacaoViewModel<Passagem>

@{
    ViewData["Title"] = "Passagens";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2"><i class="fas fa-ticket-alt"></i> @ViewData["Title"]</h1>
        <div class="btn-toolbar mb-2 mb-md-0">
            <a asp-action="Create" class="btn btn-success">
                <i class="fas fa-plus"></i> Nova Passagem
            </a>
        </div>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["Erro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filtros -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Filtros</h6>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <select name="status" class="form-select" onchange="this.form.submit()">
                        <option value="">Todos</option>
                        @foreach (var status in ViewBag.StatusOptions as string[])
                        {
                            if (ViewBag.StatusFiltro == status)
                            {
                                <option value="@status" selected>@status</option>
                            }
                            else
                            {
                                <option value="@status">@status</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Itens por página</label>
                    <select name="itensPorPagina" class="form-select" onchange="this.form.submit()">
                        @foreach (var opcao in ViewBag.ItensPorPaginaOptions as int[])
                        {
                            if (ViewBag.ItensPorPaginaAtual == opcao)
                            {
                                <option value="@opcao" selected>@opcao</option>
                            }
                            else
                            {
                                <option value="@opcao">@opcao</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-primary form-control">
                        <i class="fas fa-search"></i> Filtrar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Lista de Passagens</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-striped" width="100%" cellspacing="0">
                    <thead class="table-dark">
                        <tr>
                            <th>Nº Bilhete</th>
                            <th>Cliente</th>
                            <th>Voo</th>
                            <th>Poltrona</th>
                            <th>Data Emissão</th>
                            <th>Preço</th>
                            <th>Status</th>
                            <th width="150px">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var passagem in Model.Itens)
                        {
                            <tr>
                                <td><strong>@passagem.NumeroBilhete</strong></td>
                                <td>@passagem.Cliente?.Nome</td>
                                <td>@passagem.Voo?.NumeroVoo</td>
                                <td>@passagem.Poltrona?.NumeroPoltrona</td>
                                <td>@passagem.DataEmissao.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@passagem.Preco.ToString("C")</td>
                                <td>
                                    @if (passagem.Status == PassagemStatus.Confirmada)
                                    {
                                        <span class="badge bg-primary">@passagem.Status</span>
                                    }
                                    else if (passagem.Status == PassagemStatus.CheckIn)
                                    {
                                        <span class="badge bg-warning">@passagem.Status</span>
                                    }
                                    else if (passagem.Status == PassagemStatus.Embarcada)
                                    {
                                        <span class="badge bg-success">@passagem.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@passagem.Status</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@passagem.PassagemId" class="btn btn-info btn-sm" title="Detalhes">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        @if (passagem.Status == PassagemStatus.Confirmada)
                                        {
                                            <a asp-action="Checkin" asp-route-id="@passagem.PassagemId" class="btn btn-warning btn-sm" title="Check-in">
                                                <i class="fas fa-check-in"></i>
                                            </a>
                                        }
                                        @if (passagem.Status == PassagemStatus.CheckIn)
                                        {
                                            <a asp-action="Embarque" asp-route-id="@passagem.PassagemId" class="btn btn-success btn-sm" title="Embarque">
                                                <i class="fas fa-plane"></i>
                                            </a>
                                        }
                                        @if (passagem.Status != PassagemStatus.Cancelada && passagem.Status != PassagemStatus.Embarcada)
                                        {
                                            <a asp-action="Cancelar" asp-route-id="@passagem.PassagemId" class="btn btn-danger btn-sm"
                                               onclick="return confirm('Tem certeza que deseja cancelar esta passagem?')"
                                               title="Cancelar">
                                                <i class="fas fa-times"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Paginação -->
            @if (Model.TotalPaginas > 1)
            {
                <nav aria-label="Navegação de páginas">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.TemPaginaAnterior ? "" : "disabled")">
                            <a class="page-link" asp-route-pagina="@(Model.PaginaAtual - 1)"
                               asp-route-itensPorPagina="@ViewBag.ItensPorPaginaAtual"
                               asp-route-status="@ViewBag.StatusFiltro">
                                <i class="fas fa-chevron-left"></i> Anterior
                            </a>
                        </li>

                        @for (int i = 1; i <= Model.TotalPaginas; i++)
                        {
                            if (i == Model.PaginaAtual)
                            {
                                <li class="page-item active">
                                    <span class="page-link">@i</span>
                                </li>
                            }
                            else if (Math.Abs(i - Model.PaginaAtual) <= 2 || i == 1 || i == Model.TotalPaginas)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-route-pagina="@i"
                                       asp-route-itensPorPagina="@ViewBag.ItensPorPaginaAtual"
                                       asp-route-status="@ViewBag.StatusFiltro">@i</a>
                                </li>
                            }
                            else if (Math.Abs(i - Model.PaginaAtual) == 3)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                        }

                        <li class="page-item @(Model.TemProximaPagina ? "" : "disabled")">
                            <a class="page-link" asp-route-pagina="@(Model.PaginaAtual + 1)"
                               asp-route-itensPorPagina="@ViewBag.ItensPorPaginaAtual"
                               asp-route-status="@ViewBag.StatusFiltro">
                                Próximo <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }

            <div class="text-center text-muted">
                <small>Mostrando @Model.Itens.Count() de @Model.TotalItens passagens (Página @Model.PaginaAtual de @Model.TotalPaginas)</small>
            </div>
        </div>
    </div>

    @if (!Model.Itens.Any())
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-ticket-alt fa-2x mb-3"></i>
            <h5>Nenhuma passagem encontrada</h5>
            <p>Comece emitindo a primeira passagem do sistema.</p>
            <a asp-action="Create" class="btn btn-primary">Emitir Primeira Passagem</a>
        </div>
    }
</div>