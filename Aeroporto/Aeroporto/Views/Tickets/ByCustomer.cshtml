@using SistemaAereo.Models.Entities
@using SistemaAereo.Models.Enums
@model SistemaAereo.Models.ViewModels.PaginationViewModel<Ticket>

@{
    ViewData["Title"] = $"Passagens de {ViewBag.CustomerName}";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2"><i class="fas fa-ticket-alt"></i> Passagens de @ViewBag.CustomerName</h1>
        <div class="btn-toolbar mb-2 mb-md-0">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Voltar
            </a>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Lista de Passagens</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-striped" width="100%" cellspacing="0">
                    <thead class="table-dark">
                        <tr>
                            <th>Nº Bilhete</th>
                            <th>Voo</th>
                            <th>Poltrona</th>
                            <th>Data Emissão</th>
                            <th>Preço</th>
                            <th>Status</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ticket in Model.Items)
                        {
                            <tr>
                                <td><strong>@ticket.TicketNumber</strong></td>
                                <td>@ticket.Flight?.FlightNumber</td>
                                <td>@ticket.Seat?.SeatNumber</td>
                                <td>@ticket.IssueDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@ticket.Price.ToString("C")</td>
                                <td>
                                    @if (ticket.Status == TicketStatus.Confirmed)
                                    {
                                        <span class="badge bg-primary">@ticket.Status</span>
                                    }
                                    else if (ticket.Status == TicketStatus.CheckIn)
                                    {
                                        <span class="badge bg-warning">@ticket.Status</span>
                                    }
                                    else if (ticket.Status == TicketStatus.Boarded)
                                    {
                                        <span class="badge bg-success">@ticket.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@ticket.Status</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@ticket.TicketId" class="btn btn-info btn-sm" title="Detalhes">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Paginação -->
            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Navegação de páginas">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                            <a class="page-link" asp-route-page="@(Model.CurrentPage - 1)"
                               asp-route-itemsPerPage="@ViewBag.CurrentItemsPerPage"
                               asp-route-id="@ViewBag.CustomerId">
                                <i class="fas fa-chevron-left"></i> Anterior
                            </a>
                        </li>

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            if (i == Model.CurrentPage)
                            {
                                <li class="page-item active">
                                    <span class="page-link">@i</span>
                                </li>
                            }
                            else if (Math.Abs(i - Model.CurrentPage) <= 2 || i == 1 || i == Model.TotalPages)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-route-page="@i"
                                       asp-route-itemsPerPage="@ViewBag.CurrentItemsPerPage"
                                       asp-route-id="@ViewBag.CustomerId">@i</a>
                                </li>
                            }
                            else if (Math.Abs(i - Model.CurrentPage) == 3)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                        }

                        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                            <a class="page-link" asp-route-page="@(Model.CurrentPage + 1)"
                               asp-route-itemsPerPage="@ViewBag.CurrentItemsPerPage"
                               asp-route-id="@ViewBag.CustomerId">
                                Próximo <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>