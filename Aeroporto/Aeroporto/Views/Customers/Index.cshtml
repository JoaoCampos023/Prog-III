@using SistemaAereo.Models.Entities
@model IEnumerable<Customer>

@{
    ViewData["Title"] = "Clientes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-2 text-dark">
            <i class="fas fa-users text-primary me-2"></i>Clientes Preferenciais
        </h1>
        <p class="text-muted mb-0">Gerencie todos os clientes do sistema</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Inactive" class="btn btn-outline-secondary">
            <i class="fas fa-user-slash me-2"></i>Clientes Inativos
        </a>
        <a asp-action="MailingList" class="btn btn-outline-primary">
            <i class="fas fa-envelope me-2"></i>Mala Direta
        </a>
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-user-plus me-2"></i>Novo Cliente
        </a>
    </div>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle"></i> @TempData["Erro"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Card Principal -->
<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Lista de Clientes Ativos</h6>
        <div class="input-group input-group-sm" style="width: 250px;">
            <input type="text" class="form-control" placeholder="Buscar cliente..." id="searchInput">
            <button class="btn btn-outline-secondary" type="button" onclick="filterCustomers()">
                <i class="fas fa-search"></i>
            </button>
        </div>
    </div>
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-bordered table-striped" id="customersTable" width="100%" cellspacing="0">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Nome</th>
                            <th>Email</th>
                            <th>Telefone</th>
                            <th>Cidade/UF</th>
                            <th>Cadastro</th>
                            <th>Status</th>
                            <th width="100">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var customer in Model)
                        {
                            <tr>
                                <td>@customer.CustomerId</td>
                                <td><strong>@customer.Name</strong></td>
                                <td>@customer.Email</td>
                                <td>@(string.IsNullOrEmpty(customer.Phone) ? "—" : customer.Phone)</td>
                                <td>@(string.IsNullOrEmpty(customer.City) ? "—" : customer.City)/@customer.State</td>
                                <td>@customer.RegistrationDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (customer.IsActive)
                                    {
                                        <span class="badge bg-success">Ativo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inativo</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@customer.CustomerId" class="btn btn-warning btn-sm" title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Tem certeza que deseja excluir este cliente?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@customer.CustomerId" />
                                            <button type="submit" class="btn btn-danger btn-sm" title="Excluir">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <div class="bg-light rounded-circle d-inline-flex p-4 mb-3">
                    <i class="fas fa-users fa-2x text-muted"></i>
                </div>
                <h5 class="text-muted">Nenhum cliente cadastrado</h5>
                <p class="text-muted mb-4">Comece cadastrando o primeiro cliente do sistema.</p>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-user-plus me-2"></i>Cadastrar Primeiro Cliente
                </a>
            </div>
        }
    </div>
</div>

<!-- Estatísticas -->
@if (Model.Any())
{
    <div class="row">
        <div class="col-md-4">
            <div class="card bg-primary text-white mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-0">Total de Clientes</h6>
                            <h2 class="mb-0">@Model.Count()</h2>
                        </div>
                        <i class="fas fa-users fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-0">Clientes Ativos</h6>
                            <h2 class="mb-0">@Model.Count(c => c.IsActive)</h2>
                        </div>
                        <i class="fas fa-user-check fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-secondary text-white mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-0">Clientes Inativos</h6>
                            <h2 class="mb-0">@Model.Count(c => !c.IsActive)</h2>
                        </div>
                        <i class="fas fa-user-slash fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        function filterCustomers() {
            const input = document.getElementById('searchInput');
            const filter = input.value.toLowerCase();
            const table = document.getElementById('customersTable');
            if (!table) return;

            const rows = table.getElementsByTagName('tr');

            for (let i = 1; i < rows.length; i++) {
                const cells = rows[i].getElementsByTagName('td');
                let text = '';
                for (let j = 0; j < cells.length; j++) {
                    text += cells[j].textContent.toLowerCase() + ' ';
                }
                rows[i].style.display = text.includes(filter) ? '' : 'none';
            }
        }

        // Busca em tempo real
        const searchInput = document.getElementById('searchInput');
        if (searchInput) {
            searchInput.addEventListener('keyup', filterCustomers);
        }
    </script>
}