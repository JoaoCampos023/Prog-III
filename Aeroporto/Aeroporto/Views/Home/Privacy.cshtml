@{
    ViewData["Title"] = "Política de Privacidade";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2">@ViewData["Title"]</h1>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Política de Privacidade do Sistema Aéreo</h5>
                    <p class="card-text">
                        Esta política de privacidade descreve como coletamos, usamos e protegemos as informações
                        dos usuários do Sistema de Gestão Aérea.
                    </p>

                    <h6>Informações Coletadas</h6>
                    <ul>
                        <li>Dados de clientes (nome, email, telefone, CPF)</li>
                        <li>Informações de voos e reservas</li>
                        <li>Dados de aeronaves e aeroportos</li>
                    </ul>

                    <h6>Uso das Informações</h6>
                    <p>
                        Utilizamos as informações coletadas para gerenciar o sistema de voos,
                        clientes e operações aéreas de forma eficiente.
                    </p>

                    <h6>Proteção de Dados</h6>
                    <p>
                        Implementamos medidas de segurança para proteger suas informações
                        contra acesso não autorizado ou divulgação.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>