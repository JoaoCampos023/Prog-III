@using SistemaAereo.Models.Entities
@model IEnumerable<ClientePreferencial>

@{
    ViewData["Title"] = "Mala Direta";
    var totalClientes = ViewBag.TotalClientes;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-2 text-dark">
            <i class="fas fa-envelope text-primary me-2"></i>Mala Direta
        </h1>
        <p class="text-muted mb-0">Gerencie campanhas de email marketing</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary btn-modern">
            <i class="fas fa-arrow-left me-2"></i>Voltar
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card-modern">
            <div class="card-header-modern d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text-dark">Lista de Clientes para Mala Direta</h5>
                <span class="badge-modern bg-primary bg-opacity-10 text-primary">
                    <i class="fas fa-users me-1"></i>@totalClientes clientes ativos
                </span>
            </div>
            <div class="card-body-modern">
                <!-- Ferramentas de Ação -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="d-flex gap-2">
                            <button class="btn btn-primary-modern" onclick="copiarEmails()">
                                <i class="fas fa-copy me-2"></i>Copiar Emails
                            </button>
                            <button class="btn btn-success btn-modern" onclick="exportarCSV()">
                                <i class="fas fa-download me-2"></i>Exportar CSV
                            </button>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="input-group">
                            <input type="text" class="form-control form-control-modern"
                                   placeholder="Buscar cliente..." id="searchInput">
                            <button class="btn btn-outline-secondary" type="button" onclick="filtrarClientes()">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Lista de Clientes -->
                <div class="table-responsive">
                    <table class="table table-modern" id="tabelaClientes">
                        <thead>
                            <tr>
                                <th width="50">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="selectAll">
                                    </div>
                                </th>
                                <th>Cliente</th>
                                <th>Email</th>
                                <th>Telefone</th>
                                <th>Localização</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cliente in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="form-check">
                                            <input class="form-check-input email-checkbox" type="checkbox"
                                                   value="@cliente.Email" data-email="@cliente.Email">
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar bg-primary bg-opacity-10 text-primary rounded-circle p-2 me-3">
                                                <i class="fas fa-user"></i>
                                            </div>
                                            <div>
                                                <strong class="d-block">@cliente.Nome</strong>
                                                <small class="text-muted">ID: @cliente.ClienteId</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <i class="fas fa-envelope text-muted me-2"></i>
                                            <span class="fw-semibold">@cliente.Email</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <i class="fas fa-phone text-muted me-2"></i>
                                            <span>@(string.IsNullOrEmpty(cliente.Telefone) ? "N/A" : cliente.Telefone)</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div>
                                            <div class="fw-semibold">@(string.IsNullOrEmpty(cliente.Cidade) ? "N/A" : cliente.Cidade)</div>
                                            <small class="text-muted">@cliente.Estado</small>
                                        </div>
                                    </td>
                                    <td>
                                        @if (cliente.Ativo)
                                        {
                                            <span class="badge-modern bg-success bg-opacity-10 text-success">
                                                <i class="fas fa-check-circle me-1"></i>Ativo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge-modern bg-danger bg-opacity-10 text-danger">
                                                <i class="fas fa-times-circle me-1"></i>Inativo
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Estatísticas -->
                <div class="row mt-4">
                    <div class="col-md-3">
                        <div class="card-modern text-center">
                            <div class="card-body-modern py-3">
                                <h4 class="text-primary mb-1" id="totalSelecionados">0</h4>
                                <small class="text-muted">Selecionados</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card-modern text-center">
                            <div class="card-body-modern py-3">
                                <h4 class="text-success mb-1">@Model.Count(c => c.Ativo)</h4>
                                <small class="text-muted">Clientes Ativos</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card-modern text-center">
                            <div class="card-body-modern py-3">
                                <h4 class="text-warning mb-1">@Model.Count(c => !c.Ativo)</h4>
                                <small class="text-muted">Clientes Inativos</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card-modern text-center">
                            <div class="card-body-modern py-3">
                                <h4 class="text-info mb-1">@totalClientes</h4>
                                <small class="text-muted">Total</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <!-- Card de Ações Rápidas -->
        <div class="card-modern">
            <div class="card-header-modern">
                <h5 class="mb-0 text-dark">
                    <i class="fas fa-bolt me-2"></i>Ações Rápidas
                </h5>
            </div>
            <div class="card-body-modern">
                <div class="d-grid gap-3">
                    <button class="btn btn-primary-modern text-start p-3" onclick="copiarEmails()">
                        <div class="d-flex align-items-center">
                            <div class="bg-white bg-opacity-20 p-2 rounded me-3">
                                <i class="fas fa-copy"></i>
                            </div>
                            <div>
                                <div class="fw-semibold">Copiar Emails</div>
                                <small class="opacity-75">Copia emails para área de transferência</small>
                            </div>
                        </div>
                    </button>

                    <button class="btn btn-success btn-modern text-start p-3" onclick="exportarCSV()">
                        <div class="d-flex align-items-center">
                            <div class="bg-white bg-opacity-20 p-2 rounded me-3">
                                <i class="fas fa-download"></i>
                            </div>
                            <div>
                                <div class="fw-semibold">Exportar CSV</div>
                                <small class="opacity-75">Baixa lista em formato CSV</small>
                            </div>
                        </div>
                    </button>

                    <button class="btn btn-warning btn-modern text-start p-3" onclick="selecionarTodos()">
                        <div class="d-flex align-items-center">
                            <div class="bg-white bg-opacity-20 p-2 rounded me-3">
                                <i class="fas fa-check-square"></i>
                            </div>
                            <div>
                                <div class="fw-semibold">Selecionar Todos</div>
                                <small class="opacity-75">Marca todos os clientes</small>
                            </div>
                        </div>
                    </button>

                    <button class="btn btn-outline-secondary btn-modern text-start p-3" onclick="limparSelecao()">
                        <div class="d-flex align-items-center">
                            <div class="bg-light p-2 rounded me-3">
                                <i class="fas fa-times"></i>
                            </div>
                            <div>
                                <div class="fw-semibold">Limpar Seleção</div>
                                <small class="opacity-75">Desmarca todos os clientes</small>
                            </div>
                        </div>
                    </button>
                </div>
            </div>
        </div>

        <!-- Card de Estatísticas de Email -->
        <div class="card-modern mt-4">
            <div class="card-header-modern">
                <h5 class="mb-0 text-dark">
                    <i class="fas fa-chart-bar me-2"></i>Estatísticas
                </h5>
            </div>
            <div class="card-body-modern">
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="small text-muted">Taxa de entrega</span>
                        <span class="small fw-semibold">98%</span>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-success" style="width: 98%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="small text-muted">Taxa de abertura</span>
                        <span class="small fw-semibold">42%</span>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-primary" style="width: 42%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="small text-muted">Taxa de clique</span>
                        <span class="small fw-semibold">18%</span>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-warning" style="width: 18%"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card de Dicas -->
        <div class="card-modern mt-4">
            <div class="card-header-modern">
                <h5 class="mb-0 text-dark">
                    <i class="fas fa-lightbulb me-2"></i>Dicas
                </h5>
            </div>
            <div class="card-body-modern">
                <div class="alert-modern alert-info">
                    <ul class="mb-0 small">
                        <li>Selecione clientes específicos para campanhas segmentadas</li>
                        <li>Use a exportação CSV para importar em outras ferramentas</li>
                        <li>Clientes inativos não recebem emails automaticamente</li>
                        <li>Verifique sempre a lista antes de enviar campanhas</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Seleção de todos os checkboxes
        document.getElementById('selectAll').addEventListener('change', function() {
            const checkboxes = document.querySelectorAll('.email-checkbox');
            checkboxes.forEach(checkbox => {
                checkbox.checked = this.checked;
            });
            atualizarContador();
        });

        // Atualizar contador de selecionados
        function atualizarContador() {
            const selecionados = document.querySelectorAll('.email-checkbox:checked').length;
            document.getElementById('totalSelecionados').textContent = selecionados;
        }

        // Inicializar eventos dos checkboxes
        document.querySelectorAll('.email-checkbox').forEach(checkbox => {
            checkbox.addEventListener('change', atualizarContador);
        });

        // Selecionar todos
        function selecionarTodos() {
            document.querySelectorAll('.email-checkbox').forEach(checkbox => {
                checkbox.checked = true;
            });
            document.getElementById('selectAll').checked = true;
            atualizarContador();
        }

        // Limpar seleção
        function limparSelecao() {
            document.querySelectorAll('.email-checkbox').forEach(checkbox => {
                checkbox.checked = false;
            });
            document.getElementById('selectAll').checked = false;
            atualizarContador();
        }

        // Filtrar clientes
        function filtrarClientes() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const rows = document.querySelectorAll('#tabelaClientes tbody tr');

            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(searchTerm) ? '' : 'none';
            });
        }

        // Copiar emails para área de transferência
        function copiarEmails() {
            const emailsSelecionados = Array.from(document.querySelectorAll('.email-checkbox:checked'))
                .map(checkbox => checkbox.getAttribute('data-email'))
                .filter(email => email)
                .join('; ');

            if (!emailsSelecionados) {
                showAlert('Selecione pelo menos um cliente para copiar os emails.', 'warning');
                return;
            }

            navigator.clipboard.writeText(emailsSelecionados).then(() => {
                showAlert('Emails copiados para a área de transferência!', 'success');
            }).catch(() => {
                showAlert('Erro ao copiar emails. Tente novamente.', 'danger');
            });
        }

        // Exportar CSV
        function exportarCSV() {
            const rows = Array.from(document.querySelectorAll('#tabelaClientes tbody tr'));
            const csvContent = [
                ['Nome', 'Email', 'Telefone', 'Cidade', 'Estado', 'Status'].join(','),
                ...rows.map(row => {
                    const cells = Array.from(row.cells);
                    // Pular a primeira célula (checkbox)
                    return cells.slice(1).map(cell =>
                        `"${cell.textContent.trim().replace(/"/g, '""')}"`
                    ).join(',');
                })
            ].join('\n');

            const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.setAttribute('download', 'clientes_mala_direta.csv');
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            URL.revokeObjectURL(url);

            showAlert('Arquivo CSV exportado com sucesso!', 'success');
        }

        // Função para mostrar alertas
        function showAlert(message, type) {
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert-modern alert-${type} alert-dismissible fade show`;
            alertDiv.innerHTML = `
                <div class="d-flex align-items-center">
                    <i class="fas fa-${type === 'success' ? 'check' : 'exclamation'}-circle me-3 fa-lg"></i>
                    <div class="flex-grow-1">${message}</div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;

            document.querySelector('.content-wrapper').insertBefore(alertDiv, document.querySelector('.content-wrapper').firstChild);

            setTimeout(() => {
                alertDiv.remove();
            }, 5000);
        }

        // Inicializar
        document.addEventListener('DOMContentLoaded', function() {
            atualizarContador();

            // Evento de busca em tempo real
            document.getElementById('searchInput').addEventListener('input', filtrarClientes);
        });
    </script>

    <style>
        .avatar {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .form-check-input:checked {
            background-color: var(--primary-color);
            border-color: var(--primary-color);
        }

        .progress {
            border-radius: 10px;
        }

        .progress-bar {
            border-radius: 10px;
        }
    </style>
}